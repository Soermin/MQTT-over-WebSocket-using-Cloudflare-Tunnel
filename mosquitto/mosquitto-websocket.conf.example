# MQTT over WebSocket listener for Cloudflare Tunnel.
# Add this only after checking your existing Mosquitto configuration.

# Optional local MQTT/TCP listener. Remove this block when listener 1883
# already exists in another configuration file.
listener 1883 127.0.0.1
protocol mqtt

# cloudflared reaches this endpoint locally.
listener 8000 127.0.0.1
protocol websockets

# Authentication is mandatory for a public tunnel.
listener_allow_anonymous false
password_file /etc/mosquitto/passwd

persistence true
persistence_location /var/lib/mosquitto/
log_dest file /var/log/mosquitto/mosquitto.log
